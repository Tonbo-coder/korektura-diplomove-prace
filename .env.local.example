# Gmail SMTP – odesílání formulářů
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Příjemce objednávek (volitelné – pokud neuvedete, použije se GMAIL_USER)
RECIPIENT_EMAIL=info@formatovani-diplomove-prace.cz

# Cloudinary – nahrávání souborů (volitelné)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
